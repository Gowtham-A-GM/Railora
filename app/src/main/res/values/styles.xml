<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Splash screen title -->
    <style name="RailoraSplashTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/railora_text_primary</item>
        <item name="android:textSize">@dimen/splash_title_size</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.15</item>
    </style>

    <!-- Splash screen tagline -->
    <style name="RailoraSplashTagline" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/railora_text_primary</item>
        <item name="android:textSize">@dimen/splash_tagline_size</item>
        <item name="android:alpha">0.9</item>
    </style>


    <!-- ==================== -->
    <!-- Onboarding Typography -->
    <!-- ==================== -->

    <!-- Large title inside onboarding card -->
    <style name="RailoraOnboardingTitle">
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/onboarding_title_color</item>
    </style>

    <!-- Description below title -->
    <style name="RailoraOnboardingDescription">
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/onboarding_description_color</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <!-- Continue / Get Started button -->
    <style name="RailoraOnboardingButton">
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Back / Skip pills -->
    <style name="RailoraOnboardingTopAction">
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@android:color/white</item>
    </style>


    <!-- Login Title -->
    <style name="RailoraLoginTitle">
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">@dimen/login_title_size</item>
        <item name="android:textColor">@color/login_title_blue</item>
    </style>

    <!-- Login Labels -->
    <style name="RailoraLoginLabel">
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">@dimen/login_label_size</item>
        <item name="android:textColor">@color/login_text_primary</item>
    </style>

    <!-- Login EditText -->
    <style name="RailoraLoginInput">
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/login_text_primary</item>
        <item name="android:textColorHint">@color/login_hint</item>
    </style>

    <!-- Login Button -->
    <style name="RailoraLoginButton">
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">@dimen/login_button_text_size</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Footer Text -->
    <style name="RailoraLoginFooter">
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">@dimen/login_body_size</item>
        <item name="android:textColor">@color/login_text_primary</item>
    </style>

    <!-- Home -->

    <style name="RailoraHomeHeaderTitle">
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/login_title_blue</item>
    </style>

    <style name="RailoraHomeAppName">
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/login_title_blue</item>
    </style>

    <style name="RailoraHomeGreeting">
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/home_label_color</item>
    </style>

    <!-- Home Title -->
    <style name="RailoraHomeTitle">
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">@dimen/home_title_size</item>
        <item name="android:textColor">@color/login_text_primary</item>
    </style>

    <!-- Home Labels -->
    <style name="RailoraHomeLabel">
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">@dimen/home_label_size</item>
        <item name="android:textColor">@color/home_label_color</item>
    </style>

    <!-- Home Placeholder -->
    <style name="RailoraHomePlaceholder">
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/home_label_color</item>
    </style>

    <!-- Search Result -->

    <style name="RailoraSearchTrainName">
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">@dimen/search_result_train_name_size</item>
        <item name="android:textColor">@color/search_result_train_name</item>
    </style>

    <style name="RailoraSearchTrainNumber">
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">@dimen/search_result_train_number_size</item>
        <item name="android:textColor">@color/search_result_secondary_text</item>
    </style>

    <style name="RailoraSearchTime">
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">@dimen/search_result_time_size</item>
        <item name="android:textColor">@color/login_text_primary</item>
    </style>

    <style name="RailoraSearchStation">
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">@dimen/search_result_station_size</item>
        <item name="android:textColor">@color/search_result_secondary_text</item>
    </style>

</resources>