<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Full-screen images -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerOnboarding"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />



    <!-- Top Actions -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/onboarding_top_margin"
        android:paddingHorizontal="@dimen/spacing_md">

        <TextView
            android:id="@+id/textBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/onboarding_pill_padding_horizontal"
            android:paddingEnd="@dimen/onboarding_pill_padding_horizontal"
            android:paddingTop="@dimen/onboarding_pill_padding_vertical"
            android:paddingBottom="@dimen/onboarding_pill_padding_vertical"
            android:background="@drawable/bg_onboarding_pill"
            android:text="@string/back"
            android:textAppearance="@style/RailoraOnboardingTopAction" />

        <TextView
            android:id="@+id/textSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:paddingStart="@dimen/onboarding_pill_padding_horizontal"
            android:paddingEnd="@dimen/onboarding_pill_padding_horizontal"
            android:paddingTop="@dimen/onboarding_pill_padding_vertical"
            android:paddingBottom="@dimen/onboarding_pill_padding_vertical"
            android:background="@drawable/bg_onboarding_pill"
            android:text="@string/skip"
            android:textAppearance="@style/RailoraOnboardingTopAction" />

    </RelativeLayout>



    <!-- Indicators -->
    <me.relex.circleindicator.CircleIndicator3
        android:id="@+id/indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="@dimen/onboarding_indicator_margin_bottom" />



    <!-- Floating Bottom Card -->
    <LinearLayout
        android:id="@+id/bottomCard"
        android:layout_width="match_parent"
        android:layout_height="@dimen/onboarding_card_height"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_onboarding_card"
        android:elevation="10dp"
        android:orientation="vertical"
        android:padding="@dimen/onboarding_card_padding">

        <TextView
            android:id="@+id/textTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/RailoraOnboardingTitle" />

        <TextView
            android:id="@+id/textDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/onboarding_description_margin_top"
            android:textAppearance="@style/RailoraOnboardingDescription" />



        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />



        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonContinue"
            android:layout_width="match_parent"
            android:layout_height="@dimen/onboarding_button_height"
            android:backgroundTint="@color/onboarding_button_background"
            android:text="@string/continue_text"
            android:textAppearance="@style/RailoraOnboardingButton"
            android:textColor="@color/onboarding_button_text"
            app:cornerRadius="@dimen/onboarding_button_corner_radius"
            android:elevation="@dimen/onboarding_button_elevation"/>

    </LinearLayout>

</FrameLayout>