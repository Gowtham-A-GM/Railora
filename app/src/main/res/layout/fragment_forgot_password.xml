<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true"
    tools:context=".ui.auth.LoginFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header Image -->
        <ImageView
            android:id="@+id/ivHeader"
            android:layout_width="match_parent"
            android:layout_height="@dimen/login_header_height"
            android:contentDescription="@string/app_name"
            android:scaleType="centerCrop"
            android:src="@drawable/onboarding_1" />

        <!-- White Card -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="@dimen/login_card_overlap"
            android:background="@drawable/bg_login_card"
            android:padding="@dimen/login_horizontal_padding">

            <LinearLayout
                android:id="@+id/layoutContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Railora Logo -->
                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="@dimen/login_logo_size"
                    android:layout_height="@dimen/login_logo_size"
                    android:layout_gravity="center_horizontal"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/railora_logo_blue" />

                <!-- Enter Your Details -->
                <TextView
                    android:id="@+id/tvTitle"
                    style="@style/RailoraLoginTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="@string/forgot_password" />

                <!-- Railora Username -->
                <TextView
                    android:id="@+id/tvUsernameLabel"
                    style="@style/RailoraLoginLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:text="@string/phone_number" />

                <EditText
                    android:id="@+id/etPhoneNumber"
                    style="@style/RailoraLoginInput"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/login_input_height"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/bg_login_input"
                    android:hint="@string/enter_phone_number"
                    android:inputType="phone"
                    android:maxLength="10"
                    android:maxLines="1"
                    android:paddingHorizontal="@dimen/spacing_md" />

                <TextView
                    android:id="@+id/tvOtpLabel"
                    style="@style/RailoraLoginLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="OTP"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/layoutOtp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <EditText
                        android:id="@+id/etOtp1"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_login_input"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1" />

                    <EditText
                        android:id="@+id/etOtp2"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_login_input"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1" />

                    <EditText
                        android:id="@+id/etOtp3"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_login_input"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1" />

                    <EditText
                        android:id="@+id/etOtp4"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_login_input"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1" />

                    <EditText
                        android:id="@+id/etOtp5"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_login_input"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1" />

                    <EditText
                        android:id="@+id/etOtp6"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_login_input"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1" />

                </LinearLayout>

                <TextView
                    android:id="@+id/btnGetOtp"
                    style="@style/RailoraLoginButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/login_button_height"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:background="@drawable/bg_login_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/get_otp"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/tvBackToLogin"
                    style="@style/RailoraLoginFooter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="@string/back_to_login"
                    android:textColor="@color/login_title_blue" />

            </LinearLayout>



        </RelativeLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>