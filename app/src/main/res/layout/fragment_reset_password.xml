<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true"
    tools:context=".ui.auth.LoginFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header Image -->
        <ImageView
            android:id="@+id/ivHeader"
            android:layout_width="match_parent"
            android:layout_height="@dimen/login_header_height"
            android:contentDescription="@string/app_name"
            android:scaleType="centerCrop"
            android:src="@drawable/onboarding_1" />

        <!-- White Card -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="@dimen/login_card_overlap"
            android:background="@drawable/bg_login_card"
            android:padding="@dimen/login_horizontal_padding">

            <LinearLayout
                android:id="@+id/layoutContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Railora Logo -->
                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="@dimen/login_logo_size"
                    android:layout_height="@dimen/login_logo_size"
                    android:layout_gravity="center_horizontal"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/railora_logo_blue" />

                <!-- Enter Your Details -->
                <TextView
                    android:id="@+id/tvTitle"
                    style="@style/RailoraLoginTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="@string/reset_password" />

                <!-- Railora Username -->
                <TextView
                    android:id="@+id/tvUsernameLabel"
                    style="@style/RailoraLoginLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:text="@string/new_password" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm">

                    <EditText
                        android:id="@+id/etNewPassword"
                        style="@style/RailoraLoginInput"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/login_input_height"
                        android:background="@drawable/bg_login_input"
                        android:hint="@string/enter_new_password"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:paddingHorizontal="@dimen/spacing_md"
                        android:paddingEnd="48dp" />

                    <ImageView
                        android:id="@+id/ivNewPasswordToggle"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="12dp"
                        android:alpha="0.5"
                        android:src="@drawable/ic_eye" />

                </RelativeLayout>

                <TextView
                    style="@style/RailoraLoginLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="@string/confirm_password" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm">

                    <EditText
                        android:id="@+id/etConfirmPassword"
                        style="@style/RailoraLoginInput"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/login_input_height"
                        android:background="@drawable/bg_login_input"
                        android:hint="@string/enter_confirm_password"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:paddingHorizontal="@dimen/spacing_md"
                        android:paddingEnd="48dp" />

                    <ImageView
                        android:id="@+id/ivConfirmPasswordToggle"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="12dp"
                        android:alpha="0.5"
                        android:src="@drawable/ic_eye" />

                </RelativeLayout>

                <TextView
                    android:id="@+id/btnUpdatePassword"
                    style="@style/RailoraLoginButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/login_button_height"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:background="@drawable/bg_login_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/update_password"
                    android:textColor="@color/white" />

            </LinearLayout>



        </RelativeLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>